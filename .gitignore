# ---- Dependencies ----
node_modules/

# ---- Build output ----
# Generated by `pnpm run build` (scripts/build.js -> Vite + esbuild)
dist/
# Generated by `pnpm run zip` (scripts/zip-release.js)
release/

# ---- Chrome extension packing artifacts ----
# Produced by Chrome's "Pack extension" dev tool if used manually.
# .pem is your extension's private signing key - never commit it.
*.crx
*.pem

# ---- Testing ----
coverage/
*.lcov

# ---- Logs ----
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Env / secrets ----
.env
.env.local
.env.*.local

# ---- TypeScript build info ----
*.tsbuildinfo

# ---- Editor / IDE ----
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ---- OS files ----
.DS_Store
Thumbs.db

# ---- Package manager ----
# This project uses pnpm
package-lock.json
yarn.lock
pnpm-lock.yaml
pnpm-workspace.yaml
.npm/
.pnpm-store/